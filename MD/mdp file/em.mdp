define = -DFLEXIBLE
integrator = cg
nsteps = 5000
emtol  = 100.0
emstep = 0.01
;
nstxout   = 50
nstlog    = 50
nstenergy = 50
;
pbc = xyz
cutoff-scheme            = Verlet
coulombtype              = PME
rcoulomb                 = 1.2
vdwtype                  = Cut-off
vdw-modifier             = force-switch
rvdw-switch              = 1.0
rvdw                     = 1.2
rlist                    = 1.2
DispCorr                 = no
;
constraints              = none
